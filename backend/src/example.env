# Server Configuration
PORT=5000


# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=your_password

# Migration Database URL
DATABASE_URL=postgres://postgres:your_password@localhost:5432/inventory_db


# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379


# JWT Secret
JWT_SECRET=your_secret_key